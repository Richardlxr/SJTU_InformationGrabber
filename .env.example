# ======== SMTP 邮件配置 ========
# 支持任意 SMTP 服务商（QQ / 163 / Gmail / Outlook 等）
# 常见配置参考表：
#   QQ 邮箱   : smtp.qq.com,      465, SSL
#   163 邮箱  : smtp.163.com,     465, SSL
#   Gmail     : smtp.gmail.com,   587, STARTTLS (USE_SSL=false)
#   Outlook   : smtp.office365.com, 587, STARTTLS (USE_SSL=false)

SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
SMTP_USE_SSL=true

# 发件人邮箱地址
SENDER_EMAIL=2323805802@qq.com
# 邮箱 SMTP 授权码 / 应用专用密码（不是登录密码！）
SENDER_PASSWORD=yblgarfuadiveaah

# 收件人邮箱
RECEIVER_EMAIL=liuxinrui@sjtu.edu.cn

# ======== 爬虫配置 ========
# 监控的目标页面（逗号分隔，可自行增减）
TARGET_URLS=https://jwc.sjtu.edu.cn/xwtg.htm,https://jwc.sjtu.edu.cn/index/mxxsdtz.htm

# 检查间隔（秒），默认 300 秒 = 5 分钟
CHECK_INTERVAL=3600
