# ======== SMTP 邮件配置 ========
# 支持任意 SMTP 服务商（QQ / 163 / Gmail / Outlook 等）
# 常见配置参考表：
#   QQ 邮箱   : smtp.qq.com,      465, SSL (需开启并获取授权码)
#   163 邮箱  : smtp.163.com,     465, SSL (需开启并获取授权码)
#   Gmail     : smtp.gmail.com,   587, STARTTLS (USE_SSL=false) (需设置应用专用密码)
#   Outlook   : smtp.office365.com, 587, STARTTLS (USE_SSL=false)

SMTP_SERVER=smtp.qq.com
SMTP_PORT=465
SMTP_USE_SSL=true

# 发件人邮箱地址
SENDER_EMAIL=your_email@qq.com

# 邮箱 SMTP 授权码 / 应用专用密码（绝不是你的登录密码！）
# 请妥善保管此文件(.env)，绝对不要提交到任何公开的代码仓库中！
SENDER_PASSWORD=your_authorization_code_here

# 收件人邮箱（如果是用个人的 QQ 邮箱发出，建立自我预警，这里填相同的也可以！）
RECEIVER_EMAIL=your_email@qq.com

# ======== 爬虫配置 ========
# 监控的目标页面（逗号分隔，可自行增减，请不要在链接中加多余的空格）
TARGET_URLS=https://jwc.sjtu.edu.cn/xwtg.htm,https://jwc.sjtu.edu.cn/index/mxxsdtz.htm

# 检查间隔（秒），即程序多久去刷一次新公告，默认 300 秒 = 5 分钟
CHECK_INTERVAL=300
